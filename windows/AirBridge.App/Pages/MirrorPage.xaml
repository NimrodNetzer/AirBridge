<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AirBridge.App.Pages.MirrorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Mirror"
                   Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Connection status info bar -->
        <InfoBar Grid.Row="1"
                 IsOpen="True"
                 IsClosable="False"
                 Severity="Informational"
                 Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"/>

        <!-- Active session controls (shown while mirroring) -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Visibility="{x:Bind ViewModel.IsMirroring, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Text="Session Active"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Stop"
                        Command="{x:Bind ViewModel.StopCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Action cards (shown when not mirroring) -->
        <StackPanel Grid.Row="3"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.IsMirroring, Mode=OneWay, Converter={StaticResource BoolToVisibilityNegated}}">

            <!-- Phone window card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0"
                              Glyph="&#xE8EA;"
                              FontSize="36"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              Margin="0,0,20,0"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="Phone Window"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Mirror your Android phone on PC as a floating window"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Start"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                            Command="{x:Bind ViewModel.StartPhoneWindowCommand}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Tablet display card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0"
                              Glyph="&#xE70A;"
                              FontSize="36"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              Margin="0,0,20,0"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="Tablet Display"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Extend your Windows desktop wirelessly to an Android tablet"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Start"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                            Command="{x:Bind ViewModel.StartTabletDisplayCommand}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Disabled hint when no device connected -->
            <TextBlock Text="Connect to a device on the Devices page to enable mirroring."
                       HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolToVisibilityNegated}}"/>
        </StackPanel>
    </Grid>
</Page>
