<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="AirBridge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:AirBridge.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Bool helpers -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:BoolToVisibilityNegatedConverter x:Key="BoolToVisibilityNegated"/>
            <converters:BoolNegateConverter x:Key="BoolNegate"/>
            <!-- Scan button helpers -->
            <converters:BoolToScanIconConverter x:Key="BoolToScanIcon"/>
            <converters:BoolToScanTextConverter x:Key="BoolToScanText"/>
            <!-- Device icon -->
            <converters:DeviceTypeToIconConverter x:Key="DeviceTypeToIcon"/>
            <!-- Transfer helpers -->
            <converters:TransferStateToStringConverter x:Key="TransferStateToString"/>
            <converters:BytesToReadableConverter x:Key="BytesToReadable"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
