<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for producing a self-contained, self-signed MSIX package
  suitable for developer sideloading on Windows 11.

  Usage (from the solution root):
    dotnet publish windows/AirBridge.App/AirBridge.App.csproj \
      /p:PublishProfile=msix-sideload \
      /p:PackageCertificateThumbprint=<thumbprint>

  Or use windows/scripts/build-msix.ps1 which wraps this invocation.
-->
<Project>
  <PropertyGroup>
    <!-- MSIX packaging via EnableMsixTooling (already set in .csproj) -->
    <PublishProtocol>msix</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>

    <!-- Output directory (relative to solution root, resolved by build-msix.ps1) -->
    <PublishDir>..\..\output\msix\</PublishDir>

    <!-- Signing: thumbprint is supplied at build time via /p:PackageCertificateThumbprint -->
    <!-- AppxPackageSigningEnabled defaults to true when a thumbprint is provided -->
    <AppxPackageSigningEnabled>true</AppxPackageSigningEnabled>

    <!-- Bundle: single-arch package for sideloading (no Store bundle required) -->
    <AppxBundle>Never</AppxBundle>
    <AppxBundlePlatforms>x64</AppxBundlePlatforms>

    <!-- Ensure the package name in output is predictable -->
    <AppxPackageName>AirBridge</AppxPackageName>
  </PropertyGroup>
</Project>
