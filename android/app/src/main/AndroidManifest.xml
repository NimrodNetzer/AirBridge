<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Keep CPU awake during active file transfers -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Keep Wi-Fi radio active during an active session (prevents silent socket death) -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Network access -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Persistent background services (file transfer, mirror) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Screen capture (used by mirror module) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Notifications (transfer progress, API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- File access -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Required to write to Downloads/AirBridge on API 26-28; scoped storage handles API 29+ -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <application
        android:name=".AirBridgeApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AirBridge">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AirBridge"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Accessibility service used for touch/key injection during phone-mirror input relay.
          The user must enable it manually in Settings → Accessibility → AirBridge.
          canPerformGestures="true" is required for GestureDescription dispatch.
          canRetrieveWindowContent is intentionally false — we do not read screen content.
        -->
        <service
            android:name=".mirror.AirBridgeAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Tablet as Second Monitor: full-screen H.264 renderer (Windows → Android) -->
        <activity
            android:name=".display.TabletDisplayActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask" />

        <!--
          Persistent connection anchor: foreground service that holds WifiLock + WakeLock and
          keeps the process alive while a device session is active. Tied to dataSync because
          the app continuously transfers data (keepalives, mirror frames, file chunks).
        -->
        <service
            android:name=".core.AirBridgeConnectionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
          Phone as Floating Window: foreground service that holds the MediaProjection token,
          drives ScreenCaptureSession (MediaProjection → MediaCodec H.264), and streams
          encoded frames to the Windows PC over the active TLS channel.
          foregroundServiceType="mediaProjection" is required on API 29+ for screen capture.
        -->
        <service
            android:name=".mirror.PhoneCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
